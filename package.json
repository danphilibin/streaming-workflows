{
  "name": "relay-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm:dev:worker\" \"pnpm:dev:react\" --names \"worker,react\" --prefix-colors \"blue,magenta\"",
    "dev:worker": "pnpm --filter relay-examples dev",
    "dev:react": "pnpm --filter @relay-tools/web dev",
    "dev:e2e": "concurrently \"pnpm:dev:e2e:*\" --names \"worker,react\" --prefix-colors \"blue,magenta\"",
    "dev:e2e:worker": "pnpm --filter relay-e2e-tests dev",
    "dev:e2e:react": "pnpm --filter @relay-tools/web dev --port 5174",
    "build": "pnpm -r build",
    "deploy:all": "bash scripts/deploy.sh",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @relay-tools/sdk test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "lefthook install",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm -r build && changeset publish",
    "===== PACKAGES =====": "",
    "examples": "pnpm --filter relay-examples",
    "web": "pnpm --filter @relay-tools/web",
    "sdk": "pnpm --filter @relay-tools/sdk"
  },
  "dependencies": {
    "@relay-tools/sdk": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.57.0",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.1",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "tsx": "^4.21.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
