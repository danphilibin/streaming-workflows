{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "relay-sdk-test",
  "main": "./worker.ts",
  "compatibility_date": "2025-12-21",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "RELAY_EXECUTOR",
        "class_name": "RelayExecutor"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": [
        "RelayExecutor"
      ]
    }
  ]
}