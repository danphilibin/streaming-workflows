# Local development override for the relay worker URL.
# Copy to .env to use:  cp .env.example .env
#
# When unset, requests use relative paths and Vite's dev proxy forwards
# /api, /stream, /workflows to localhost:8787 automatically.
#
# For production deploys, create .env.production with your worker URL.
# See README.md for details.
VITE_RELAY_WORKER_URL=http://localhost:8787
