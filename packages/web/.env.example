# Vite env vars — copy to .env for local development.
#
# The worker URL (RELAY_WORKER_URL) is configured separately in .dev.vars
# for local dev and as a Cloudflare secret for production.

# WorkOS AuthKit
WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
WORKOS_COOKIE_PASSWORD=  # min 32 chars, generate with: openssl rand -base64 24
